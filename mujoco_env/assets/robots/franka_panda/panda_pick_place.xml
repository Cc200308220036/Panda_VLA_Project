<mujoco model="panda pick place">

  <include file="panda.xml"/>

  <statistic center="0.45 0 0.45" extent="1.2"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>

    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
             markrgb="0.8 0.8 0.8" width="300" height="300"/>

    <material name="groundplane" texture="groundplane" texuniform="true"
              texrepeat="5 5" reflectance="0.2"/>

    <material name="table_mat" rgba="0.55 0.38 0.22 1"/>
    <material name="red_cube_mat" rgba="0.9 0.05 0.05 1"/>
    <material name="green_target_mat" rgba="0.05 0.8 0.1 0.45"/>
  </asset>

  <worldbody>
    <light name="top_light" pos="0 0 1.5" mode="trackcom"/>

    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Table.
        table center x = 0.62
        table half size x = 0.36
        table x range = [0.26, 0.98]
        table top height = 0.40
        This keeps the table away from the Panda base.
    -->
    <body name="table" pos="0.62 0 0.20">
      <geom name="table_top"
            type="box"
            size="0.36 0.32 0.20"
            material="table_mat"
            contype="1"
            conaffinity="1"
            friction="1.0 0.005 0.0001"/>
    </body>

    <!-- Red cube.
        cube half size = 0.025
        table top height = 0.40
        cube center z = 0.425
    -->
    <body name="red_cube" pos="0.52 -0.10 0.425">
      <freejoint name="red_cube_freejoint"/>
      <geom name="red_cube_geom"
            type="box"
            size="0.025 0.025 0.025"
            material="red_cube_mat"
            mass="0.03"
            contype="1"
            conaffinity="1"
            friction="1.5 0.01 0.0001"/>
    </body>

    <!-- Green target zone.
        Visual target only.
    -->
    <body name="green_target" pos="0.66 0.16 0.403">
      <geom name="green_target_geom"
            type="cylinder"
            size="0.07 0.003"
            material="green_target_mat"
            contype="0"
            conaffinity="0"/>
    </body>

    <!-- Top camera.
        Clear debug camera for dataset inspection.
    -->
    <camera name="top"
            pos="0.4584 0.0264 1.4694"
            xyaxes="1.0000 0.0000 -0.0088 -0.0001 1.0000 -0.0073"
            fovy="56.7"/>

    lookat = 0.4485 0.0182 0.3424

    <!-- Front camera.
        Oblique view, useful for image-based policy.
    -->
    <camera name="front"
            pos="1.00 -0.65 0.80"
            xyaxes="0.707 0.707 0 -0.408 0.408 0.816"
            fovy="50"/>

    <!-- Side debug camera.
        Useful for checking whether the gripper reaches cube height correctly.
    -->
    <camera name="side"
            pos="0.5442 -1.0704 0.8140"
            xyaxes="1.0000 0.0043 -0.0000 -0.0013 0.2898 0.9571"
            fovy="64.1"/>

    lookat = 0.5395 0.0105 0.4866


    <camera name="front_policy"
            pos="1.4000 0.0408 0.6777"
            xyaxes="-0.0060 1.0000 0.0000 -0.0255 -0.0002 0.9997"
            fovy="55.5"/>

    lookat = 0.4335 0.0350 0.6530

    <camera name="front_debug"
            pos="0.5442 -1.0704 0.8140"
            xyaxes="1.0000 0.0043 -0.0000 -0.0013 0.2898 0.9571"
            fovy="64.1"/>

    lookat = 0.5395 0.0105 0.4866


  </worldbody>

</mujoco>
